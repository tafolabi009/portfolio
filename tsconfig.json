{
    "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "moduleResolution": "Node",
      "jsx": "react-jsx",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true,
      "noEmit": false,
      "isolatedModules": true,
      "skipLibCheck": true,
      "lib": ["DOM", "ESNext"],
      "outDir": "build"
    },
    "include": ["app/**/*", "entry.server.tsx", "vite.config.ts"],
    "exclude": ["node_modules", "build"]
  }